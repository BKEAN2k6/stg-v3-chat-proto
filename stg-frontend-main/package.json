{
  "name": "stg-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "test": "jest",
    "build": "tsc && vite build",
    "lint": "tsc && xo",
    "lint:fix": "xo --fix",
    "preview": "vite preview",
    "i18n-sync": "lingui extract && lingui compile",
    "i18n-sync-and-purge": "lingui extract --clean && lingui compile"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^16.6.0",
    "@lingui/conf": "^4.7.0",
    "@lingui/core": "^4.7.0",
    "@lingui/macro": "^4.11.2",
    "@lingui/react": "^4.11.2",
    "bootstrap": "^5.3.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "element-resize-event": "^3.0.6",
    "front-matter": "^4.0.2",
    "js-cookie": "^3.0.5",
    "linkify-react": "^4.1.3",
    "linkifyjs": "^4.1.3",
    "react": "18.2.0",
    "react-avatar-editor": "^13.0.2",
    "react-bootstrap": "^2.10.4",
    "react-bootstrap-icons": "^1.11.4",
    "react-bootstrap-typeahead": "^6.3.2",
    "react-confetti-explosion": "^2.1.2",
    "react-confirm": "^0.3.0-7",
    "react-datepicker": "^7.3.0",
    "react-dom": "18.2.0",
    "react-dropzone": "^14.2.3",
    "react-error-boundary": "^4.0.13",
    "react-image-gallery": "^1.3.0",
    "react-markdown": "^9.0.1",
    "react-photo-album": "^2.4.1",
    "react-player": "^2.16.0",
    "react-qr-code": "^2.0.15",
    "react-router-bootstrap": "^0.26.3",
    "react-router-dom": "^6.24.1",
    "react-spinners": "^0.13.8",
    "react-textarea-autosize": "^8.5.3",
    "react-timeago": "^7.2.0",
    "react-timezone-select": "^3.2.5",
    "react-tracking": "^9.3.2",
    "react-use": "^17.5.0",
    "rehype-slug": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.0",
    "socket.io-client": "^4.7.5",
    "yet-another-react-lightbox": "^3.21.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@lingui/cli": "^4.7.0",
    "@lingui/vite-plugin": "^4.11.2",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^14.3.1",
    "@types/element-resize-event": "^3.0.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.3",
    "@types/react-avatar-editor": "^13.0.2",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^18.3.0",
    "@types/react-router-bootstrap": "^0.26.6",
    "@types/react-timeago": "^4.1.7",
    "@types/react-tracking": "^8.1.6",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-legacy": "^5.4.2",
    "@vitejs/plugin-react": "^4.3.1",
    "babel-plugin-macros": "^3.1.0",
    "babel-plugin-transform-regex": "^4.1.1",
    "eslint": "^8.57.0",
    "eslint-config-xo-react": "^0.27.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.8",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "sass": "^1.77.8",
    "terser": "^5.31.6",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "xo": "^0.56.0"
  },
  "overrides": {
    "mdast-util-gfm@3.0.0": {
      "mdast-util-gfm-autolink-literal": "2.0.0"
    }
  },
  "xo": {
    "ignores": [
      "src/languages"
    ],
    "extends": "xo-react",
    "prettier": true,
    "space": true,
    "rules": {
      "react/react-in-jsx-scope": "off",
      "import/extensions": "off",
      "@typescript-eslint/triple-slash-reference": "off",
      "unicorn/filename-case": [
        "error",
        {
          "cases": {
            "pascalCase": true,
            "camelCase": true,
            "kebabCase": true
          }
        }
      ],
      "capitalized-comments": "off"
    }
  }
}
