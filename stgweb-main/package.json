{
  "name": "next-template",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev-check": "yarn lint && yarn typecheck && yarn test",
    "dev-with-turbo": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "xo",
    "lint:fix": "xo --fix",
    "preview": "next build && next start",
    "typecheck": "tsc --noEmit",
    "test": "jest --collectCoverage",
    "test:watch": "jest --watch --collectCoverage"
  },
  "dependencies": {
    "@directus/sdk": "^10.3.3",
    "@p5-wrapper/next": "^0.2.0",
    "@p5-wrapper/react": "^4.2.0",
    "@radix-ui/react-dialog": "^1.0.4",
    "@radix-ui/react-slot": "^1.0.2",
    "@rive-app/react-canvas": "^4.1.2",
    "@sentry/nextjs": "^7.66.0",
    "@sentry/node": "^7.74.1",
    "@types/jest": "^29.5.5",
    "@types/qs": "^6.9.7",
    "@types/seedrandom": "^3.0.5",
    "api": "^6.1.0",
    "class-variance-authority": "^0.4.0",
    "clsx": "^1.2.1",
    "date-fns": "^2.30.0",
    "embla-carousel-react": "^8.0.0-rc10",
    "framer-motion": "^10.12.18",
    "gsap": "^3.12.2",
    "html-to-image": "^1.11.11",
    "intersection-observer": "^0.12.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jwt-decode": "^3.1.2",
    "lucide-react": "0.105.0-alpha.4",
    "next": "^13.5.2",
    "next-client-cookies": "^1.0.2",
    "next-themes": "^0.2.1",
    "p5": "^1.7.0",
    "prop-types": "^15.8.1",
    "qrcode.react": "^3.1.0",
    "qs": "^6.11.2",
    "react": "^18.2.0",
    "react-canvas-confetti": "^1.4.0",
    "react-confetti": "^6.1.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-joyride": "^2.5.5",
    "react-string-replace": "^1.1.1",
    "react-textarea-autosize": "^8.5.2",
    "react-use": "^17.4.0",
    "recharts": "^2.8.0",
    "seedrandom": "^3.0.5",
    "sharp": "^0.31.3",
    "sidemail": "^0.1.6",
    "styled-components": "^6.1.0",
    "tailwind-merge": "^1.12.0",
    "tailwindcss-animate": "^1.0.5",
    "use-context-selector": "^1.4.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.1.0",
    "@ianvs/prettier-plugin-sort-imports": "^3.7.2",
    "@testing-library/jest-dom": "^6.1.3",
    "@testing-library/react": "^14.0.0",
    "@types/node": "^17.0.45",
    "@types/p5": "^1.7.0",
    "@types/react": "^18.2.7",
    "@types/react-dom": "^18.2.4",
    "@typescript-eslint/parser": "^5.59.7",
    "autoprefixer": "^10.4.14",
    "encoding": "^0.1.13",
    "eslint": "^8.41.0",
    "eslint-config-next": "13.0.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-config-xo": "^0.43.1",
    "eslint-config-xo-nextjs": "^5.2.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-tailwindcss": "^3.12.0",
    "postcss": "^8.4.24",
    "prettier": "^2.8.8",
    "tailwindcss": "^3.3.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "xo": "^0.56.0"
  },
  "xo": {
    "extends": [
      "xo",
      "eslint-config-xo-nextjs",
      "plugin:tailwindcss/recommended"
    ],
    "rules": {
      "@next/next/no-html-link-for-pages": "off",
      "@typescript-eslint/consistent-type-assertions": "off",
      "@typescript-eslint/naming-convention": "off",
      "@typescript-eslint/no-floating-promises": "off",
      "@typescript-eslint/no-unsafe-argument": "off",
      "@typescript-eslint/no-unsafe-assignment": "off",
      "@typescript-eslint/no-unsafe-call": "off",
      "@typescript-eslint/no-unsafe-return": "off",
      "capitalized-comments": "off",
      "import/extensions": "off",
      "n/file-extension-in-import": "off",
      "n/prefer-global/buffer": "off",
      "n/prefer-global/process": "off",
      "react-hooks/exhaustive-deps": "off",
      "tailwindcss/no-custom-classname": "off",
      "unicorn/filename-case": "off",
      "unicorn/prefer-module": "off",
      "unicorn/numeric-separators-style": "off",
      "no-unused-vars": "off",
      "@typescript-eslint/no-unused-vars": [
        "error"
      ],
      "no-undef": "off",
      "camelcase": "off"
    },
    "space": 2,
    "prettier": true,
    "ignores": [
      "tailwind.config.js",
      "postcss.config.js"
    ]
  }
}
